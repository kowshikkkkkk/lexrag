cat > .env.example << 'EOF'
# LLM
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL_FAST=llama-3.1-8b-instant
GROQ_MODEL_QUALITY=llama-3.3-70b-versatile

# Embeddings
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

# Vector Store
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=lexrag_legal
QDRANT_VECTOR_SIZE=768

# Retrieval
DENSE_TOP_K=20
SPARSE_TOP_K=20
FINAL_TOP_K=5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MIN_SIMILARITY_THRESHOLD=0.30
REVIEW_THRESHOLD=2.0

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# MLflow
MLFLOW_TRACKING_URI=sqlite:///data/mlflow/mlflow.db
MLFLOW_EXPERIMENT_NAME=lexrag_experiments

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Evaluation
GOLDEN_DATASET_PATH=./data/processed/golden_qa.json
EOF